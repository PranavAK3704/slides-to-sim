# ── Required ─────────────────────────────────────────────────
# Gemini API (free) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Slides API (free) — https://console.cloud.google.com
# Enable "Google Slides API" then create an API key
GOOGLE_API_KEY=your_google_api_key_here

# ── Optional ──────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
OUTPUT_DIR=./output
